{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QONTOS Benchmark Report",
  "description": "Schema for benchmark reports generated by qontos-bench",
  "type": "object",
  "required": [
    "generated_at",
    "total_benchmarks",
    "passed",
    "failed",
    "results"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of report generation"
    },
    "total_benchmarks": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of benchmarks executed"
    },
    "passed": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of benchmarks that passed"
    },
    "failed": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of benchmarks that failed"
    },
    "results": {
      "type": "array",
      "description": "Individual benchmark results",
      "items": {
        "type": "object",
        "required": [
          "name",
          "circuit_type",
          "num_qubits",
          "shots",
          "counts",
          "expected_states",
          "dominant_state",
          "dominant_probability",
          "fidelity",
          "execution_time_ms",
          "timestamp",
          "passed"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable benchmark name"
          },
          "circuit_type": {
            "type": "string",
            "description": "Circuit category identifier",
            "enum": ["bell", "ghz", "qft", "bv", "vqe", "random"]
          },
          "num_qubits": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of qubits in the circuit"
          },
          "shots": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of measurement shots"
          },
          "counts": {
            "type": "object",
            "description": "Measurement outcome counts keyed by bitstring",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "expected_states": {
            "type": "array",
            "description": "List of expected dominant output bitstrings",
            "items": {
              "type": "string"
            }
          },
          "dominant_state": {
            "type": "string",
            "description": "Most frequently observed bitstring"
          },
          "dominant_probability": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Probability of the dominant state"
          },
          "fidelity": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Fraction of shots in expected states"
          },
          "execution_time_ms": {
            "type": "number",
            "minimum": 0.0,
            "description": "Simulation wall-clock time in milliseconds"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 timestamp of this benchmark execution"
          },
          "passed": {
            "type": "boolean",
            "description": "Whether fidelity met the pass threshold"
          },
          "metadata": {
            "type": "object",
            "description": "Optional additional metadata",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
