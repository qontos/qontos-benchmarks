{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QONTOS Benchmark Report",
  "type": "object",
  "required": ["version", "timestamp", "suite", "environment", "results", "summary"],
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "timestamp": {"type": "string", "format": "date-time"},
    "suite": {"type": "string"},
    "environment": {
      "type": "object",
      "properties": {
        "python_version": {"type": "string"},
        "qontos_version": {"type": "string"},
        "backend": {"type": "string"},
        "shots": {"type": "integer"},
        "seed": {"type": "integer"}
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "qubits", "fidelity", "passed", "latency_ms"],
        "properties": {
          "name": {"type": "string"},
          "qubits": {"type": "integer"},
          "family": {"type": "string"},
          "fidelity": {"type": "number"},
          "passed": {"type": "boolean"},
          "latency_ms": {"type": "number"},
          "shots": {"type": "integer"},
          "metadata": {"type": "object"},
          "expected_states": {"type": "array", "items": {"type": "string"}},
          "top_counts": {"type": "object"}
        }
      }
    },
    "family_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "family": {"type": "string"},
          "total": {"type": "integer"},
          "passed": {"type": "integer"},
          "failed": {"type": "integer"},
          "pass_rate": {"type": "number"},
          "avg_fidelity": {"type": "number"}
        }
      }
    },
    "stressor_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stressor": {"type": "string"},
          "total": {"type": "integer"},
          "passed": {"type": "integer"},
          "failed": {"type": "integer"},
          "pass_rate": {"type": "number"},
          "avg_fidelity": {"type": "number"}
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total": {"type": "integer"},
        "passed": {"type": "integer"},
        "failed": {"type": "integer"},
        "pass_rate": {"type": "number"},
        "avg_fidelity": {"type": "number"},
        "total_latency_ms": {"type": "number"}
      }
    },
    "readiness": {
      "type": "object",
      "properties": {
        "version": {"type": "string"},
        "generated_at": {"type": "string"},
        "scenario": {"type": "string"},
        "gate_status": {"type": "object"},
        "software_lab": {"type": "object"},
        "prioritized_actions": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
